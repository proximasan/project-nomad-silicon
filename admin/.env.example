PORT=8080
HOST=localhost
LOG_LEVEL=info
APP_KEY=some_random_key
NODE_ENV=development
SESSION_DRIVER=cookie
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_DATABASE=nomad
DB_PASSWORD=password
DB_SSL=false
REDIS_HOST=localhost
REDIS_PORT=6379
# Storage path for NOMAD content (ZIM files, maps, etc.)
# On Windows dev, use an absolute path like: C:/nomad-storage
# On Linux production, use: /opt/project-nomad/storage
# On macOS, use an absolute path like: /Users/yourname/project-nomad/storage
NOMAD_STORAGE_PATH=/opt/project-nomad/storage
# Native Ollama support (macOS Metal acceleration)
# Uncomment to use Ollama running natively on macOS instead of in Docker.
# This enables Metal/MPS GPU acceleration on Apple Silicon.
# OLLAMA_HOST=http://host.docker.internal:11434
# Apple chip model — injected by the macOS install script for accurate hardware detection.
# APPLE_CHIP_MODEL=Apple M3 Pro